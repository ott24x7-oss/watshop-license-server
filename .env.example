# --- WatShop License Server ---

# Port the HTTP server listens on (Railway injects this automatically)
PORT=3000

# Where SQLite + RS256 keypair are stored.
# In production (Railway), mount a volume here so data persists between deploys.
DATA_DIR=./data

# Cookie signing secret (random string, 32+ chars).
# Generate with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-random-string

# First-deploy admin bootstrap.
# If no admin exists when the server starts and these are set, an admin is created.
# Remove BOOTSTRAP_ADMIN_PASSWORD from env after first successful login.
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=

# How long activation JWT remains valid before the desktop app must heartbeat
# (defaults to 90 days). Lifetime licenses still need periodic re-validation
# so revoked keys eventually stop working on the device.
JWT_TTL_DAYS=90
